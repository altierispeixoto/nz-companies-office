    {
      "id": "PKri",
      "code_hash": "7db382860bc094500ec257b608c39dbc",
      "outputs": [
        {
          "type": "data",
          "data": {
            "text/markdown": "<span class=\"markdown prose dark:prose-invert contents\"><h2 id=\"depth-first-search-dfs\">Depth-First Search (DFS)</h2>\n<span class=\"paragraph\"><strong>DFS</strong> explores a graph by going as deep as possible along each branch before backtracking.</span>\n<blockquote>\n<span class=\"paragraph\">\ud83e\udde0 <strong>Analogy</strong>: Exploring a maze \u2014 you follow a path until you hit a dead end, then backtrack.</span>\n</blockquote>\n<span class=\"paragraph\"><strong>Key property</strong>: DFS is great for topological sorting, detecting cycles, and solving mazes.</span></span>"
          }
        }
      ],
      "console": []
    },
