    {
      "id": "SFPL",
      "code_hash": "d64185947ac8fe59896eb09dca44492a",
      "outputs": [
        {
          "type": "data",
          "data": {
            "text/markdown": "<span class=\"markdown prose dark:prose-invert contents\"><h2 id=\"bfs-vs-dfs-when-to-use-what\">BFS vs DFS \u2014 When to Use What?</h2>\n<table>\n<thead>\n<tr>\n<th>Criteria</th>\n<th>BFS</th>\n<th>DFS</th>\n</tr>\n</thead>\n<tbody>\n<tr>\n<td><strong>Shortest path</strong> (unweighted)</td>\n<td>\u2705 Guaranteed</td>\n<td>\u274c Not guaranteed</td>\n</tr>\n<tr>\n<td><strong>Memory</strong></td>\n<td><marimo-tex class=\"arithmatex\">||(\\mathcal{O}(w)||)</marimo-tex> \u2014 width can be large</td>\n<td><marimo-tex class=\"arithmatex\">||(\\mathcal{O}(d)||)</marimo-tex> \u2014 depth usually smaller</td>\n</tr>\n<tr>\n<td><strong>Cycle detection</strong></td>\n<td>Can detect</td>\n<td>\u2705 Excellent</td>\n</tr>\n<tr>\n<td><strong>Topological sort</strong></td>\n<td>\u274c</td>\n<td>\u2705</td>\n</tr>\n<tr>\n<td><strong>Connected components</strong></td>\n<td>\u2705</td>\n<td>\u2705</td>\n</tr>\n</tbody>\n</table>\n<span class=\"paragraph\">Both have <marimo-tex class=\"arithmatex\">||(\\mathcal{O}(V + E)||)</marimo-tex> time complexity \u2014 they visit every node and edge once.</span></span>"
          }
        }
      ],
      "console": []
    },
